# Copy to .env and edit. docker-compose.yml reads these.
# Everything here is OPTIONAL — the defaults work for a plain LAN install.

# Where to read aircraft.json from (your dump1090/readsb web server).
# DUMP1090_URL=http://192.168.1.50:8080/data/aircraft.json

# Optional OpenWeatherMap key for the cloud weather layer (rain radar needs none).
# OWM_API_KEY=

# --- Cloudflare Tunnel (only needed if you run: docker compose --profile cloudflared up -d) ---
# Token from Cloudflare Zero Trust → Networks → Tunnels (the long eyJh... string).
# CLOUDFLARE_TUNNEL_TOKEN=

# Set to 1 when behind the tunnel / a reverse proxy so brute-force lockouts and
# logs use the real client IP (CF-Connecting-IP) instead of the proxy address.
# TRUST_PROXY=1
